@model CoffeSolution.ViewModels.ProductViewModel
@{
    ViewData["Title"] = "Thêm sản phẩm mới";
}

<!-- Page Header -->
<div class="page-header">
    <h1>Thêm sản phẩm mới</h1>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>
</div>

<!-- Create Form -->
<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div class="row">
        <div class="col-lg-8">
            <div class="card mb-3">
                <div class="card-header">
                    <h5 class="mb-0">Thông tin cơ bản</h5>
                </div>
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Tên sản phẩm <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="VD: Cà phê đen đá" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    @if (ViewBag.Stores != null)
                    {
                        <div class="mb-3">
                            <label asp-for="StoreId" class="form-label">Cửa hàng</label>
                            <select asp-for="StoreId" class="form-select" asp-items="ViewBag.Stores">
                            </select>
                            <span asp-validation-for="StoreId" class="text-danger"></span>
                            <div class="form-text">Để trống để tạo sản phẩm dùng chung cho cả hệ thống</div>
                        </div>
                    }

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Mô tả</label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Mô tả chi tiết về sản phẩm..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Category" class="form-label">Danh mục</label>
                            <select asp-for="Category" class="form-select">
                                <option value="">-- Chọn danh mục --</option>
                                <option value="Coffee">Cà phê</option>
                                <option value="Tea">Trà</option>
                                <option value="Juice">Sinh tố</option>
                                <option value="Food">Bánh ngọt</option>
                            </select>
                            <span asp-validation-for="Category" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Unit" class="form-label">Đơn vị tính</label>
                            <input asp-for="Unit" class="form-control" placeholder="VD: Ly, Cốc, Hộp" />
                            <span asp-validation-for="Unit" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header">
                    <h5 class="mb-0">Giá & Kho</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Price" class="form-label">Giá bán <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input asp-for="Price" type="number" class="form-control text-mono" placeholder="0" min="0" step="1000" />
                                <span class="input-group-text">đ</span>
                            </div>
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="StockQuantity" class="form-label">Tồn kho ban đầu</label>
                            <input asp-for="StockQuantity" type="number" class="form-control text-mono" placeholder="0" min="0" />
                            <span asp-validation-for="StockQuantity" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card mb-3">
                <div class="card-header">
                    <h5 class="mb-0">Hình ảnh sản phẩm</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="ImageUrl" class="form-label">URL hình ảnh</label>
                        <input asp-for="ImageUrl" type="text" class="form-control" placeholder="https://..." />
                        <span asp-validation-for="ImageUrl" class="text-danger"></span>
                        <small class="text-muted d-block mt-1">Nhập đường dẫn hình ảnh sản phẩm</small>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Trạng thái</h5>
                </div>
                <div class="card-body">
                    <div class="form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                        <label asp-for="IsActive" class="form-check-label">
                            Sản phẩm đang bán
                        </label>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-body">
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-circle"></i> Lưu sản phẩm
                </button>
                <button type="reset" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-counterclockwise"></i> Đặt lại
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-auto">
                    <i class="bi bi-x-circle"></i> Hủy
                </a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
