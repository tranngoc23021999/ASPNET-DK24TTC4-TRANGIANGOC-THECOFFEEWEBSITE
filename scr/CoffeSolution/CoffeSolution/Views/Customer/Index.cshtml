@model IEnumerable<CoffeSolution.Models.Entities.Customer>
@{
    ViewData["Title"] = "Quản lý khách hàng";
}

<div class="page-header">
    <h1>Quản lý khách hàng</h1>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Thêm khách hàng
        </a>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-5">
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="search" class="form-control" placeholder="Tìm theo tên, email, SĐT, mã..." value="@ViewBag.Search" />
                </div>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-outline-primary w-100">
                    <i class="bi bi-funnel"></i> Lọc
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Mã KH</th>
                        <th>Tên khách hàng</th>
                        <th>Cửa hàng</th>
                        <th>Điện thoại</th>
                        <th>Email</th>
                        <th>Địa chỉ</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var customer in Model)
                        {
                            <tr>
                                <td>@customer.Code</td>
                                <td>
                                    <i class="bi bi-person text-coffee-medium"></i>
                                    @customer.Name
                                </td>
                                <td>
                                    @if (customer.Store != null)
                                    {
                                        <span class="badge bg-info">@customer.Store.Name</span>
                                    }
                                    else if (customer.UserId != null)
                                    {
                                        <span class="badge bg-warning text-dark">Toàn bộ cửa hàng</span>
                                        <small class="d-block text-muted">(@customer.User?.FullName)</small>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Toàn hệ thống</span>
                                    }
                                </td>
                                <td>@customer.Phone</td>
                                <td>@customer.Email</td>
                                <td>@customer.Address</td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Edit" asp-route-id="@customer.Id" class="btn btn-outline-primary">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <button type="button" class="btn btn-outline-danger" onclick="deleteCustomer(@customer.Id)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="bi bi-people" style="font-size: 3rem; opacity: 0.3;"></i>
                                <p class="mt-2">Chưa có khách hàng nào</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        function deleteCustomer(id) {
            if (confirm('Bạn có chắc muốn xóa khách hàng này?')) {
                fetch(`/Customer/Delete/${id}`, { 
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                })
                .then(response => {
                    if (response.ok) {
                        location.reload();
                    } else {
                        alert('Không thể xóa khách hàng này (Có thể đang được sử dụng)');
                    }
                })
                .catch(error => alert('Lỗi hệ thống'));
            }
        }
    </script>
}
