@{
    ViewData["Title"] = "Truy cập bị từ chối";
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
}

<div class="auth-card">
    <div class="access-denied-container">
        <div class="access-denied-icon">
            <i class="bi bi-shield-fill-exclamation"></i>
        </div>
        
        <h1 class="access-denied-title">Truy cập bị từ chối</h1>
        
        <p class="access-denied-message">
            Bạn không có quyền truy cập trang này.<br />
            Vui lòng liên hệ quản trị viên nếu bạn cần trợ giúp.
        </p>
        
        <div class="access-denied-actions">
            <a asp-controller="Auth" asp-action="Logout" class="btn btn-outline-primary">
                <i class="bi bi-box-arrow-left"></i> Đăng xuất
            </a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                <i class="bi bi-house-fill"></i> Về trang chủ
            </a>
        </div>
    </div>
</div>
