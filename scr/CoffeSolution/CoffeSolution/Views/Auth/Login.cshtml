@model CoffeSolution.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
}

<div class="auth-card">
    <div class="auth-header">
        <div class="auth-brand">
            <i class="bi bi-cup-hot-fill"></i>
            <span>CoffeSolution</span>
        </div>
        <h1 class="auth-title">Đăng nhập</h1>
        <p class="auth-subtitle">Chào mừng bạn trở lại!</p>
    </div>

    <form asp-action="Login" method="post" class="auth-form">
        <input type="hidden" asp-for="ReturnUrl" />

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="auth-alert auth-alert-danger">
                <i class="bi bi-exclamation-circle-fill"></i>
                <div>
                    @Html.ValidationSummary(true, "", new { @class = "mb-0" })
                </div>
            </div>
        }

        <div class="form-group">
            <label asp-for="Username" class="form-label">Tên đăng nhập</label>
            <div class="input-group">
                <i class="bi bi-person-fill input-group-icon"></i>
                <input asp-for="Username" class="form-control" placeholder="Nhập tên đăng nhập" autofocus />
            </div>
            <span asp-validation-for="Username" class="text-danger small"></span>
        </div>

        <div class="form-group">
            <label asp-for="Password" class="form-label">Mật khẩu</label>
            <div class="input-group">
                <i class="bi bi-lock-fill input-group-icon"></i>
                <input asp-for="Password" class="form-control" placeholder="Nhập mật khẩu" />
            </div>
            <span asp-validation-for="Password" class="text-danger small"></span>
        </div>

        <div class="form-check">
            <input asp-for="RememberMe" class="form-check-input" id="rememberMe" />
            <label asp-for="RememberMe" class="form-check-label" for="rememberMe">
                Ghi nhớ đăng nhập
            </label>
        </div>

        <button type="submit" class="btn btn-auth">
            <i class="bi bi-box-arrow-in-right"></i>
            Đăng nhập
        </button>

        <div class="auth-links">
            <a href="#" class="auth-link">Quên mật khẩu?</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
