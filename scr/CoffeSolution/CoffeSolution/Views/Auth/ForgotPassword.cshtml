@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
}

<div class="auth-card">
    <div class="auth-header">
        <div class="auth-brand">
            <i class="bi bi-cup-hot-fill"></i>
            <span>CoffeSolution</span>
        </div>
        <h1 class="auth-title">Quên mật khẩu?</h1>
        <p class="auth-subtitle">Nhập email để đặt lại mật khẩu</p>
    </div>

    <form method="post" class="auth-form">
        <div class="auth-alert auth-alert-info">
            <i class="bi bi-info-circle-fill"></i>
            <div>
                Chúng tôi sẽ gửi link đặt lại mật khẩu đến email của bạn.
            </div>
        </div>

        <div class="form-group">
            <label for="email" class="form-label">Email</label>
            <div class="input-group">
                <i class="bi bi-envelope-fill input-group-icon"></i>
                <input type="email" id="email" name="email" class="form-control" placeholder="Nhập địa chỉ email" required autofocus />
            </div>
        </div>

        <button type="submit" class="btn btn-auth">
            <i class="bi bi-send-fill"></i>
            Gửi link đặt lại
        </button>

        <div class="auth-links">
            <a asp-controller="Auth" asp-action="Login" class="auth-link">
                <i class="bi bi-arrow-left"></i> Quay lại đăng nhập
            </a>
        </div>
    </form>
</div>
