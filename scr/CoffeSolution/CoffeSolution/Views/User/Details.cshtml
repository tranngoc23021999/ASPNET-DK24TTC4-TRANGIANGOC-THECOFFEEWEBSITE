@model CoffeSolution.Models.Entities.User
@{
    ViewData["Title"] = "Chi tiết người dùng";
}

<div class="page-header">
    <h1>Chi tiết người dùng</h1>
    <div class="page-actions">
        @if (ViewBag.CanEdit == true)
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                <i class="bi bi-pencil"></i> Chỉnh sửa
            </a>
        }
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-3">
                    <div class="avatar-lg">
                        @Model.FullName.Substring(0, 1).ToUpper()
                    </div>
                    <div>
                        <h5 class="mb-0">@Model.FullName</h5>
                        <small class="text-muted">@@@Model.Username</small>
                    </div>
                </div>
                @if (Model.IsActive)
                {
                    <span class="badge badge-success">Hoạt động</span>
                }
                else
                {
                    <span class="badge badge-secondary">Ngừng hoạt động</span>
                }
            </div>
            <div class="card-body">
                <div class="row mb-4">
                    <div class="col-md-6">
                        <label class="form-label text-muted small">Email</label>
                        <div>
                            @if (!string.IsNullOrEmpty(Model.Email))
                            {
                                <a href="mailto:@Model.Email">@Model.Email</a>
                            }
                            else
                            {
                                <span class="text-muted">Chưa cập nhật</span>
                            }
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted small">Số điện thoại</label>
                        <div>
                            @if (!string.IsNullOrEmpty(Model.Phone))
                            {
                                <a href="tel:@Model.Phone">@Model.Phone</a>
                            }
                            else
                            {
                                <span class="text-muted">Chưa cập nhật</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label class="form-label text-muted small">Vai trò</label>
                        <div>
                            @if (Model.UserRoles?.Any() == true)
                            {
                                @foreach (var ur in Model.UserRoles)
                                {
                                    <span class="badge badge-info">@ur.Role?.Name</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">Chưa gán vai trò</span>
                            }
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted small">Quản lý bởi</label>
                        <div>@(Model.Admin?.FullName ?? "Hệ thống")</div>
                    </div>
                </div>

                <hr />

                <div class="row text-muted small">
                    <div class="col-md-6">
                        <strong>Ngày tạo:</strong> @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                    </div>
                </div>
            </div>
        </div>

        <!-- Stores -->
        @if (Model.UserStores?.Any() == true)
        {
            <div class="card mt-4">
                <div class="card-header">
                    <h6 class="mb-0"><i class="bi bi-shop"></i> Cửa hàng được phân công (@Model.UserStores.Count)</h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Mã</th>
                                    <th>Tên cửa hàng</th>
                                    <th>Địa chỉ</th>
                                    <th>Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var us in Model.UserStores)
                                {
                                    <tr>
                                        <td><code>@(us.Store?.Code ?? "-")</code></td>
                                        <td>@us.Store?.Name</td>
                                        <td>@(us.Store?.Address ?? "-")</td>
                                        <td>
                                            @if (us.Store?.IsActive == true)
                                            {
                                                <span class="badge badge-success">Hoạt động</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-secondary">Ngừng</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0">Thao tác</h6>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    @if (ViewBag.CanEdit == true)
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">
                            <i class="bi bi-pencil"></i> Chỉnh sửa thông tin
                        </a>
                        <form asp-action="ToggleStatus" asp-route-id="@Model.Id" method="post">
                            @if (Model.IsActive)
                            {
                                <button type="submit" class="btn btn-outline-warning w-100">
                                    <i class="bi bi-pause-circle"></i> Tạm khóa tài khoản
                                </button>
                            }
                            else
                            {
                                <button type="submit" class="btn btn-outline-success w-100">
                                    <i class="bi bi-play-circle"></i> Kích hoạt tài khoản
                                </button>
                            }
                        </form>
                    }
                    @if (ViewBag.CanDelete == true)
                    {
                        <button type="button" class="btn btn-outline-danger" onclick="deleteUser(@Model.Id)">
                            <i class="bi bi-trash"></i> Xóa người dùng
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        function deleteUser(id) {
            if (confirm('Bạn có chắc muốn xóa người dùng này? Hành động này không thể hoàn tác.')) {
                fetch(`/User/Delete/${id}`, { 
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                })
                .then(r => r.ok ? window.location.href = '/User' : alert('Lỗi khi xóa (Có thể người dùng này đang là Chủ cửa hàng hoặc có dữ liệu liên quan)'));
            }
        }
    </script>
}

<style>
    .avatar-lg {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: var(--coffee-gradient);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1.5rem;
    }
</style>
