@model CoffeSolution.Models.Entities.Shift

@{
    ViewData["Title"] = "Chi tiết Shift";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Chi tiết Shift #@Model.Id</h1>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
            <h6 class="m-0 font-weight-bold text-primary">Thông tin ca làm việc</h6>
            @if (ViewBag.CanEdit == true)
            {
                 <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-warning">
                    <i class="bi bi-pencil"></i> Sửa
                </a>
            }
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Cửa hàng</label>
                    <p class="form-control-plaintext">@Model.Store?.Name</p>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Nhân viên</label>
                    <p class="form-control-plaintext">@Model.Staff?.FullName (@Model.Staff?.Username)</p>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Thời gian bắt đầu</label>
                    <p class="form-control-plaintext">@Model.StartTime.ToString("dd/MM/yyyy HH:mm:ss")</p>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Thời gian kết thúc</label>
                    <p class="form-control-plaintext">@(Model.EndTime?.ToString("dd/MM/yyyy HH:mm:ss") ?? "Chưa kết thúc")</p>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                     <label class="form-label fw-bold">Tiền đầu ca</label>
                     <p class="form-control-plaintext">@Model.StartingCash.ToString("N0")</p>
                </div>
                <div class="col-md-6 mb-3">
                     <label class="form-label fw-bold">Tiền kết ca</label>
                     <p class="form-control-plaintext">@(Model.EndingCash?.ToString("N0") ?? "-")</p>
                </div>
            </div>
            
            <div class="row">
                 <div class="col-md-12 mb-3">
                    <label class="form-label fw-bold">Tổng doanh thu (Hệ thống tính)</label>
                    <div class="input-group">
                         <span class="input-group-text">TM</span>
                         <input type="text" class="form-control" value="@Model.TotalRevenueCash.ToString("N0")" disabled />
                         <span class="input-group-text">Thẻ</span>
                         <input type="text" class="form-control" value="@Model.TotalRevenueCard.ToString("N0")" disabled />
                         <span class="input-group-text">CK</span>
                         <input type="text" class="form-control" value="@Model.TotalRevenueTransfer.ToString("N0")" disabled />
                    </div>
                 </div>
            </div>
            
            @if(Model.Status == "Closed" && Model.EndingCash.HasValue)
            {
                <div class="row">
                    <div class="col-md-12">
                        <div class="alert alert-info">
                            @{
                                var expected = Model.StartingCash + Model.TotalRevenueCash;
                                var diff = Model.EndingCash.Value - expected;
                                var statusText = diff == 0 ? "Khớp" : (diff > 0 ? "Dư" : "Thiếu");
                                var diffClass = diff == 0 ? "text-success" : (diff > 0 ? "text-success" : "text-danger");
                            }
                            <strong>Đối soát tiền mặt:</strong> 
                            <ol>
                                <li>Đầu ca (@Model.StartingCash.ToString("N0")) + Thu TM (@Model.TotalRevenueCash.ToString("N0")) = <strong>@expected.ToString("N0")</strong></li>
                                <li>Thực tế: <strong>@Model.EndingCash.Value.ToString("N0")</strong></li>
                                <li>Kết quả: <span class="@diffClass fw-bold">@statusText @Math.Abs(diff).ToString("N0")</span></li>
                            </ol>
                        </div>
                    </div>
                </div>
            }

            <div class="mt-3">
                <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
            </div>
        </div>
    </div>
</div>
