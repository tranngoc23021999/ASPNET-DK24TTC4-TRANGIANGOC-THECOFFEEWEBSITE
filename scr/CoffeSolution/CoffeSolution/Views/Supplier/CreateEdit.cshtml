@model CoffeSolution.ViewModels.SupplierViewModel
@{
    ViewData["Title"] = Model?.Id > 0 ? "Chỉnh sửa nhà cung cấp" : "Thêm nhà cung cấp";
    var isEdit = Model?.Id > 0;
}

<div class="page-header">
    <h1>@ViewData["Title"]</h1>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Thông tin nhà cung cấp</h5>
            </div>
            <div class="card-body">
                <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
                    @if (isEdit) { <input type="hidden" asp-for="Id" /> }
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                @if (ViewBag.Stores != null)
                {
                    <div class="mb-3">
                        <label asp-for="StoreId" class="form-label control-label">Phạm vi áp dụng / Cửa hàng</label>
                        <select asp-for="StoreId" class="form-select" asp-items="ViewBag.Stores">
                        </select>
                        <span asp-validation-for="StoreId" class="text-danger"></span>
                        <div class="form-text">Chọn "Áp dụng cho tất cả..." để nhà cung cấp này có sẵn ở mọi cửa hàng.</div>
                    </div>
                }

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Tên NCC <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="Tên nhà cung cấp" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="ContactPerson" class="form-label">Người liên hệ</label>
                            <input asp-for="ContactPerson" class="form-control" placeholder="Tên người liên hệ" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Phone" class="form-label">Số điện thoại</label>
                            <input asp-for="Phone" class="form-control" placeholder="0123 456 789" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email</label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="email@example.com" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Address" class="form-label">Địa chỉ</label>
                        <textarea asp-for="Address" class="form-control" rows="2" placeholder="Địa chỉ nhà cung cấp"></textarea>
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" checked="@(!isEdit)" />
                            <label asp-for="IsActive" class="form-check-label">Đang hoạt động</label>
                        </div>
                    </div>

                    <hr />

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle"></i> @(isEdit ? "Cập nhật" : "Lưu")
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0">Hướng dẫn</h6>
            </div>
            <div class="card-body">
                <p class="small text-muted">Nhập đầy đủ thông tin nhà cung cấp để quản lý nguồn hàng hiệu quả.</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
