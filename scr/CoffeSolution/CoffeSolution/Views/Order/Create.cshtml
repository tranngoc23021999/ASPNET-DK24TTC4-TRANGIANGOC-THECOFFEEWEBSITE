@model CoffeSolution.ViewModels.OrderViewModel
@{
    ViewData["Title"] = "Tạo đơn hàng mới";
}

<!-- Page Header -->
<div class="page-header">
    <h1>Tạo đơn hàng mới</h1>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>
</div>

<form asp-action="Create" method="post">
    <div class="row">
        <div class="col-lg-8">
            <div class="card mb-3">
                <div class="card-header">
                    <h5 class="mb-0">Thông tin đơn hàng</h5>
                </div>
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="StoreId" class="form-label">Cửa hàng <span class="text-danger">*</span></label>
                        <select asp-for="StoreId" class="form-select" asp-items="ViewBag.Stores">
                            <option value="">-- Chọn cửa hàng --</option>
                        </select>
                        <span asp-validation-for="StoreId" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="PaymentMethod" class="form-label">Phương thức thanh toán</label>
                            <select asp-for="PaymentMethod" class="form-select">
                                <option value="Cash">Tiền mặt</option>
                                <option value="Card">Thẻ</option>
                                <option value="Transfer">Chuyển khoản</option>
                            </select>
                            <span asp-validation-for="PaymentMethod" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="TotalAmount" class="form-label">Tổng tiền tạm tính</label>
                            <div class="input-group">
                                <input asp-for="TotalAmount" type="number" class="form-control text-mono" min="0" step="1000" />
                                <span class="input-group-text">đ</span>
                            </div>
                            <span asp-validation-for="TotalAmount" class="text-danger"></span>
                            <small class="text-muted">Lưu ý: Đây chỉ là tạo nhanh, chi tiết sản phẩm sẽ được thêm sau khi tạo.</small>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Note" class="form-label">Ghi chú</label>
                        <textarea asp-for="Note" class="form-control" rows="3" placeholder="Ghi chú thêm về đơn hàng..."></textarea>
                        <span asp-validation-for="Note" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-check-circle"></i> Tạo đơn hàng
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            Hủy
                        </a>
                    </div>
                </div>
            </div>

            <div class="alert alert-info mt-3">
                <i class="bi bi-info-circle"></i>
                Sau khi tạo đơn hàng, bạn sẽ được chuyển đến trang chi tiết để thêm sản phẩm vào đơn hàng.
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
