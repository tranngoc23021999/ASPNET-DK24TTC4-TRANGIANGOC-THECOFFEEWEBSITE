<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CoffeSolution</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@700&family=Poppins:wght@500;600&display=swap" rel="stylesheet" />
    
    <!-- Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    
    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    
    <!-- Coffee Theme Styles -->
    <link href="~/css/base-variables.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/components.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/landing.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/responsive.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
</head>
<body class="public-body">
    <!-- Skip to main content for accessibility -->
    <a href="#main-content" class="skip-to-content">Skip to main content</a>

    <!-- Public Header -->
    <header class="public-header">
        <nav class="navbar navbar-expand-lg">
            <div class="container">
                <a class="navbar-brand" href="/">
                    <i class="bi bi-cup-hot-fill"></i>
                    <span class="brand-text">CoffeSolution</span>
                </a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <i class="bi bi-list"></i>
                </button>
                
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="#about">Về chúng tôi</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#menu">Thực đơn</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#stores">Cửa hàng</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#contact">Liên hệ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-cta" asp-controller="Auth" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- Main Content -->
    <main id="main-content">
        @RenderBody()
    </main>

    <!-- Public Footer -->
    <footer class="public-footer">
        <div class="container">
            <div class="row">
                <div class="col-lg-4 mb-4 mb-lg-0">
                    <div class="footer-brand">
                        <i class="bi bi-cup-hot-fill"></i>
                        <span>CoffeSolution</span>
                    </div>
                    <p class="footer-description">
                        Hương vị đích thực của cà phê Việt Nam. 
                        Mang đến trải nghiệm cà phê tuyệt vời nhất cho khách hàng.
                    </p>
                    <div class="footer-social">
                        <a href="#" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                        <a href="#" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                        <a href="#" aria-label="Twitter"><i class="bi bi-twitter"></i></a>
                        <a href="#" aria-label="YouTube"><i class="bi bi-youtube"></i></a>
                    </div>
                </div>
                
                <div class="col-lg-2 col-md-4 mb-4 mb-lg-0">
                    <h5 class="footer-title">Liên kết</h5>
                    <ul class="footer-links">
                        <li><a href="#about">Về chúng tôi</a></li>
                        <li><a href="#menu">Thực đơn</a></li>
                        <li><a href="#stores">Cửa hàng</a></li>
                        <li><a href="#contact">Liên hệ</a></li>
                    </ul>
                </div>
                
                <div class="col-lg-3 col-md-4 mb-4 mb-lg-0">
                    <h5 class="footer-title">Giờ mở cửa</h5>
                    <ul class="footer-hours">
                        <li><span>Thứ 2 - Thứ 6:</span> 7:00 - 22:00</li>
                        <li><span>Thứ 7 - CN:</span> 8:00 - 23:00</li>
                    </ul>
                </div>
                
                <div class="col-lg-3 col-md-4">
                    <h5 class="footer-title">Liên hệ</h5>
                    <ul class="footer-contact">
                        <li>
                            <i class="bi bi-geo-alt-fill"></i>
                            123 Đường ABC, Quận XYZ, TP.HCM
                        </li>
                        <li>
                            <i class="bi bi-telephone-fill"></i>
                            (028) 1234 5678
                        </li>
                        <li>
                            <i class="bi bi-envelope-fill"></i>
                            info@coffesolution.vn
                        </li>
                    </ul>
                </div>
            </div>
            
            <hr class="footer-divider" />
            
            <div class="footer-bottom">
                <p>&copy; @DateTime.Now.Year CoffeSolution. All rights reserved.</p>
                <div class="footer-bottom-links">
                    <a href="#">Privacy Policy</a>
                    <a href="#">Terms of Service</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
