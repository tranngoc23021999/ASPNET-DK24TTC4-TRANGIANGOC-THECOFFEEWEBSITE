@model IEnumerable<CoffeSolution.Models.Entities.Menu>

<nav class="sidebar">
    <div class="sidebar-header">
        <i class="bi bi-cup-hot-fill brand-icon"></i>
        <span class="brand-name">CoffeSolution</span>
    </div>

    <ul class="sidebar-menu">
        @foreach (var menu in Model.OrderBy(m => m.Order))
        {
            var isActive = ViewContext.RouteData.Values["controller"]?.ToString()?.Equals(
                menu.Code.Replace("_", ""), StringComparison.OrdinalIgnoreCase) == true;

            <li class="menu-item @(isActive ? "active" : "")">
                <a href="@menu.Url">
                    <i class="@menu.Icon"></i>
                    <span>@menu.Name</span>
                </a>
            </li>
        }
    </ul>

    <div class="sidebar-footer">
        <a asp-controller="Auth" asp-action="ChangePassword">
            <i class="bi bi-key-fill"></i> Đổi mật khẩu
        </a>
        <a asp-controller="Auth" asp-action="Logout">
            <i class="bi bi-box-arrow-right"></i> Đăng xuất
        </a>
    </div>
</nav>

<!-- Sidebar Overlay for Mobile -->
<div class="sidebar-overlay" id="sidebarOverlay"></div>
