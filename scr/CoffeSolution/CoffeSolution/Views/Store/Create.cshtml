@model CoffeSolution.ViewModels.StoreViewModel
@{
    ViewData["Title"] = "Thêm cửa hàng mới";
}

<div class="page-header">
    <h1>Thêm cửa hàng mới</h1>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Thông tin cửa hàng</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Code" class="form-label">Mã cửa hàng</label>
                            <input asp-for="Code" class="form-control" placeholder="VD: CH01" />
                            <span asp-validation-for="Code" class="text-danger"></span>
                        </div>

                        <div class="col-md-8 mb-3">
                            <label asp-for="Name" class="form-label">Tên cửa hàng <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" placeholder="VD: Coffee House Quận 1" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Address" class="form-label">Địa chỉ</label>
                        <textarea asp-for="Address" class="form-control" rows="2" placeholder="Số nhà, đường, phường/xã..."></textarea>
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Phone" class="form-label">Số điện thoại</label>
                            <input asp-for="Phone" class="form-control" placeholder="0123 456 789" />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Email" class="form-label">Email</label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="store@example.com" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                            <label asp-for="IsActive" class="form-check-label">Đang hoạt động</label>
                        </div>
                    </div>

                    @if (ViewBag.IsAdministrator == true)
                    {
                        <div class="mb-3">
                            <label asp-for="OwnerId" class="form-label">
                                Chủ sở hữu (Admin) <span class="text-danger">*</span>
                            </label>
                            <select asp-for="OwnerId" asp-items="@ViewBag.Admins" class="form-select">
                                <option value="">-- Chọn Admin --</option>
                            </select>
                            <span asp-validation-for="OwnerId" class="text-danger"></span>
                            <small class="text-muted">Chọn Admin sẽ quản lý cửa hàng này</small>
                        </div>
                    }

                    <hr />

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle"></i> Lưu
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0">Hướng dẫn</h6>
            </div>
            <div class="card-body">
                <ul class="small text-muted mb-0">
                    <li>Mã cửa hàng nên ngắn gọn (VD: CH01, HCM02)</li>
                    <li>Tên cửa hàng là bắt buộc</li>
                    <li>Điện thoại và email dùng để liên hệ</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
