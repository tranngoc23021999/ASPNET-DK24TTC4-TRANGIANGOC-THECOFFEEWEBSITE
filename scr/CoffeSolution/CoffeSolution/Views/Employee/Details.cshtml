@using CoffeSolution.Models.Entities
@model User

@{
    ViewData["Title"] = "Chi tiết nhân viên";
}

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex justify-content-between align-items-center">
                <h6 class="m-0 font-weight-bold text-primary">Chi tiết nhân viên: @Model.Username</h6>
                <div>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm">
                        <i class="bi bi-pencil-square"></i> Sửa
                    </a>
                    <a asp-action="Index" class="btn btn-secondary btn-sm">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                </div>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">Tên đăng nhập</dt>
                    <dd class="col-sm-9">@Model.Username</dd>

                    <dt class="col-sm-3">Họ tên</dt>
                    <dd class="col-sm-9">@Model.FullName</dd>

                    <dt class="col-sm-3">Email</dt>
                    <dd class="col-sm-9">@(Model.Email ?? "-")</dd>

                    <dt class="col-sm-3">Số điện thoại</dt>
                    <dd class="col-sm-9">@(Model.Phone ?? "-")</dd>

                    <dt class="col-sm-3">Vai trò</dt>
                    <dd class="col-sm-9">
                        @foreach (var ur in Model.UserRoles)
                        {
                            <span class="badge bg-info text-dark mr-1">@ur.Role.Name</span>
                        }
                    </dd>

                    <dt class="col-sm-3">Cửa hàng</dt>
                    <dd class="col-sm-9">
                        @if (Model.UserStores.Any())
                        {
                            foreach (var us in Model.UserStores)
                            {
                                <span class="badge bg-secondary mr-1">@us.Store.Name</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted">Chưa gán cửa hàng</span>
                        }
                    </dd>

                    <dt class="col-sm-3">Trạng thái</dt>
                    <dd class="col-sm-9">
                        @if (Model.IsActive)
                        {
                            <span class="text-success"><i class="bi bi-check-circle-fill"></i> Hoạt động</span>
                        }
                        else
                        {
                            <span class="text-danger"><i class="bi bi-x-circle-fill"></i> Đã khóa</span>
                        }
                    </dd>

                    <dt class="col-sm-3">Người tạo/QL</dt>
                    <dd class="col-sm-9">
                        @(Model.Admin?.FullName ?? "Hệ thống / Administrator")
                    </dd>

                    <dt class="col-sm-3">Ngày tạo</dt>
                    <dd class="col-sm-9">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>
                </dl>
            </div>
        </div>
    </div>
</div>
