@model CoffeSolution.Models.Entities.Role
@{
    ViewData["Title"] = "Chi tiết vai trò";
}

<div class="page-header">
    <h1>Chi tiết vai trò</h1>
    <div class="page-actions">
        @if (ViewBag.CanEdit == true && !Model.IsSystem)
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                <i class="bi bi-pencil"></i> Chỉnh sửa
            </a>
        }
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-shield-check text-coffee-medium" style="font-size: 1.5rem;"></i>
                    <h5 class="mb-0">@Model.Name</h5>
                </div>
                @if (Model.IsSystem)
                {
                    <span class="badge badge-warning">
                        <i class="bi bi-lock-fill"></i> Vai trò hệ thống
                    </span>
                }
                else
                {
                    <span class="badge badge-secondary">Tùy chỉnh</span>
                }
            </div>
            <div class="card-body">
                <div class="mb-4">
                    <label class="form-label text-muted small">Mô tả</label>
                    <div>@(Model.Description ?? "Không có mô tả")</div>
                </div>

                <div class="row text-muted small">
                    <div class="col-md-6">
                        <strong>Ngày tạo:</strong> @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                    </div>
                    <div class="col-md-6">
                        <strong>Số người dùng:</strong> @(Model.UserRoles?.Count ?? 0) người
                    </div>
                </div>
            </div>
        </div>

        <!-- Permissions -->
        @if (Model.RoleMenuPermissions?.Any() == true)
        {
            <div class="card mt-4">
                <div class="card-header">
                    <h6 class="mb-0"><i class="bi bi-shield-lock"></i> Quyền được gán</h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-bordered mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Menu</th>
                                    <th>Quyền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var permissionsByMenu = Model.RoleMenuPermissions
                                        .GroupBy(p => p.Menu)
                                        .OrderBy(g => g.Key?.Order);
                                }
                                @foreach (var group in permissionsByMenu)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <i class="@group.Key?.Icon text-coffee-medium"></i>
                                                <span>@group.Key?.Name</span>
                                            </div>
                                        </td>
                                        <td>
                                            @foreach (var perm in group.OrderBy(p => p.MenuAction?.Code))
                                            {
                                                var actionName = perm.MenuAction?.Code switch
                                                {
                                                    "VIEW" => "Xem",
                                                    "CREATE" => "Thêm",
                                                    "EDIT" => "Sửa",
                                                    "DELETE" => "Xóa",
                                                    _ => perm.MenuAction?.Code
                                                };
                                                <span class="badge badge-success me-1">@actionName</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        <!-- Users with this role -->
        @if (Model.UserRoles?.Any() == true)
        {
            <div class="card mt-4">
                <div class="card-header">
                    <h6 class="mb-0"><i class="bi bi-people"></i> Người dùng có vai trò này (@Model.UserRoles.Count)</h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Người dùng</th>
                                    <th>Email</th>
                                    <th>Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ur in Model.UserRoles.Take(10))
                                {
                                    <tr>
                                        <td>
                                            <a asp-controller="User" asp-action="Details" asp-route-id="@ur.User?.Id">
                                                @ur.User?.FullName
                                            </a>
                                            <small class="text-muted d-block">@@@ur.User?.Username</small>
                                        </td>
                                        <td>@(ur.User?.Email ?? "-")</td>
                                        <td>
                                            @if (ur.User?.IsActive == true)
                                            {
                                                <span class="badge badge-success">Hoạt động</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-secondary">Ngừng</span>
                                            }
                                        </td>
                                    </tr>
                                }
                                @if (Model.UserRoles.Count > 10)
                                {
                                    <tr>
                                        <td colspan="3" class="text-center text-muted">
                                            ... và @(Model.UserRoles.Count - 10) người dùng khác
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0">Thao tác</h6>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    @if (ViewBag.CanEdit == true && !Model.IsSystem)
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">
                            <i class="bi bi-pencil"></i> Chỉnh sửa vai trò
                        </a>
                    }
                    @if (ViewBag.CanDelete == true && !Model.IsSystem && (Model.UserRoles?.Count ?? 0) == 0)
                    {
                        <button type="button" class="btn btn-outline-danger" onclick="deleteRole(@Model.Id)">
                            <i class="bi bi-trash"></i> Xóa vai trò
                        </button>
                    }
                </div>
                
                @if (Model.IsSystem)
                {
                    <div class="alert alert-warning mt-3 mb-0 small">
                        <i class="bi bi-info-circle"></i>
                        Vai trò hệ thống không thể sửa hoặc xóa.
                    </div>
                }
                else if ((Model.UserRoles?.Count ?? 0) > 0)
                {
                    <div class="alert alert-info mt-3 mb-0 small">
                        <i class="bi bi-info-circle"></i>
                        Không thể xóa vai trò đang được sử dụng.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        function deleteRole(id) {
            if (confirm('Bạn có chắc muốn xóa vai trò này?')) {
                fetch(`/Role/Delete/${id}`, { 
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                })
                .then(r => r.ok ? window.location.href = '/Role' : alert('Lỗi khi xóa (Vai trò đang được sử dụng hoặc là vai trò hệ thống)'));
            }
        }
    </script>
}
