@model CoffeSolution.ViewModels.RoleViewModel
@{
    ViewData["Title"] = "Chỉnh sửa vai trò";
    var menus = ViewBag.Menus as List<CoffeSolution.Models.Entities.Menu>;
}

<div class="page-header">
    <h1>Chỉnh sửa vai trò</h1>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Thông tin vai trò</h5>
                </div>
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Name" class="form-label">
                                Tên vai trò <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Description" class="form-label">Mô tả</label>
                            <input asp-for="Description" class="form-control" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Permissions Matrix -->
            <div class="card mt-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-shield-lock"></i> Phân quyền</h5>
                    <div class="btn-group btn-group-sm">
                        <button type="button" class="btn btn-outline-primary" onclick="selectAll()">
                            <i class="bi bi-check-all"></i> Chọn tất cả
                        </button>
                        <button type="button" class="btn btn-outline-secondary" onclick="deselectAll()">
                            <i class="bi bi-x-circle"></i> Bỏ chọn
                        </button>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-bordered mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 200px;">Menu</th>
                                    <th class="text-center">Xem</th>
                                    <th class="text-center">Thêm</th>
                                    <th class="text-center">Sửa</th>
                                    <th class="text-center">Xóa</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (menus != null)
                                {
                                    @foreach (var menu in menus)
                                    {
                                        var menuPermissions = Model.Permissions.ContainsKey(menu.Code) 
                                            ? Model.Permissions[menu.Code] 
                                            : new List<string>();
                                        
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center gap-2">
                                                    <i class="@menu.Icon text-coffee-medium"></i>
                                                    <span>@menu.Name</span>
                                                </div>
                                            </td>
                                            @foreach (var actionCode in new[] { "VIEW", "CREATE", "EDIT", "DELETE" })
                                            {
                                                var action = menu.MenuActions?.FirstOrDefault(a => a.Code == actionCode);
                                                var isChecked = menuPermissions.Contains(actionCode);
                                                <td class="text-center">
                                                    @if (action != null)
                                                    {
                                                        <input type="checkbox" 
                                                               name="Permissions[@menu.Code]" 
                                                               value="@actionCode"
                                                               class="form-check-input permission-checkbox"
                                                               checked="@isChecked" />
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>
                                            }
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-circle"></i> Lưu thay đổi
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
            </div>
        </form>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0">Lưu ý</h6>
            </div>
            <div class="card-body">
                <ul class="small text-muted mb-0">
                    <li>Thay đổi quyền sẽ áp dụng ngay cho tất cả người dùng có vai trò này</li>
                    <li>Hãy cẩn thận khi bỏ bớt quyền</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function selectAll() {
            document.querySelectorAll('.permission-checkbox').forEach(cb => cb.checked = true);
        }
        function deselectAll() {
            document.querySelectorAll('.permission-checkbox').forEach(cb => cb.checked = false);
        }
    </script>
}
