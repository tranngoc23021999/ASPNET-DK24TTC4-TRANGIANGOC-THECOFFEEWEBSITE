@model IEnumerable<CoffeSolution.ViewModels.RoleListViewModel>
@{
    ViewData["Title"] = "Quản lý vai trò";
}

<div class="page-header">
    <h1>Quản lý vai trò</h1>
    <div class="page-actions">
        @if (ViewBag.CanCreate == true)
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Thêm vai trò
            </a>
        }
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Tên vai trò</th>
                        <th>Mô tả</th>
                        <th>Loại</th>
                        <th>Số người dùng</th>
                        <th>Ngày tạo</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var role in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <i class="bi bi-shield-check text-coffee-medium"></i>
                                        <strong>@role.Name</strong>
                                    </div>
                                </td>
                                <td>@(role.Description ?? "-")</td>
                                <td>
                                    @if (role.IsSystem)
                                    {
                                        <span class="badge badge-warning">
                                            <i class="bi bi-lock-fill"></i> Hệ thống
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-secondary">Tùy chỉnh</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge badge-info">@role.UserCount người</span>
                                </td>
                                <td>@role.CreatedAt.ToString("dd/MM/yyyy")</td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Details" asp-route-id="@role.Id" 
                                           class="btn btn-outline-info" title="Chi tiết">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (ViewBag.CanEdit == true && !role.IsSystem)
                                        {
                                            <a asp-action="Edit" asp-route-id="@role.Id" 
                                               class="btn btn-outline-primary" title="Sửa">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        }
                                        @if (ViewBag.CanDelete == true && !role.IsSystem && role.UserCount == 0)
                                        {
                                            <button type="button" class="btn btn-outline-danger" 
                                                    onclick="deleteRole(@role.Id)" title="Xóa">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="bi bi-shield" style="font-size: 3rem; opacity: 0.3;"></i>
                                <p class="mt-2">Chưa có vai trò nào</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="alert alert-info mt-4">
    <i class="bi bi-info-circle me-2"></i>
    <strong>Lưu ý:</strong> Vai trò hệ thống (Administrator, Admin, Leader, Staff) không thể sửa hoặc xóa.
    Vai trò đang được sử dụng bởi người dùng cũng không thể xóa.
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        function deleteRole(id) {
            if (confirm('Bạn có chắc muốn xóa vai trò này?')) {
                fetch(`/Role/Delete/${id}`, { 
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                })
                .then(r => r.ok ? location.reload() : alert('Lỗi khi xóa (Vai trò đang được sử dụng hoặc là vai trò hệ thống)'));
            }
        }
    </script>
}
